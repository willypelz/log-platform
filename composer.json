{
    "name": "willypelz/laravel-log-platform",
    "description": "Production-grade logging and monitoring platform for Laravel applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "WillyPelz",
            "email": "willypelz@example.com"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Willypelz\\LogPlatform\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Willypelz\\LogPlatform\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Willypelz\\LogPlatform\\LogPlatformServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-html coverage",
        "test:filter": "vendor/bin/phpunit --filter"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
